{
  "manifest_version": 3,
  "name": "Instagram Cleaner",
  "version": "1.0",
  "description": "Finds users who do not follow you back.",
  "action": {
    "default_popup": "popup.html"
  },
  "permissions": [
    "scripting",
    "activeTab",
    "storage"
  ],
  "host_permissions": [
    "https://*.instagram.com/*"
  ]
}